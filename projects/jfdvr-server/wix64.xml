<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs" xmlns:fire="http://wixtoolset.org/schemas/v4/wxs/firewall" xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package UpgradeCode="{DAF6D3A4-EAA6-4748-80FD-D1B7AEE46365}" Version="0.43" Language="1033" Name="jfDVR Server" Manufacturer="Peter Quiring" InstallerVersion="300">
    <Media Id="1" Cabinet="files.cab" EmbedCab="yes" />
    <UIRef Id="WixUI_Minimal" />
    <MajorUpgrade DowngradeErrorMessage="A later version of [ProductName] is already installed. Setup will now exit." />

    <SetProperty Id="URL" Value="http://localhost" Sequence="execute" Before="CreateShortcuts" />
    <Icon Id="icon.ico" SourceFile="jfdvr-server.ico" />
    <Property Id="ARPPRODUCTICON" Value="icon.ico" />

    <!-- Step 1: Define the directory structure -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="APPLICATIONROOTDIRECTORY" Name="jfDVR-Server" />
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="APPLICATIONDATADIRECTORY_JAVAFORCE" Name="JavaForce">
        <Directory Id="APPLICATIONDATADIRECTORY_JFADMIN" Name="admin" />
      </Directory>
    </StandardDirectory>

    <!-- Step 2: Add files to your installer package -->
    <DirectoryRef Id="APPLICATIONROOTDIRECTORY">
      <Component Id="appfiles" Guid="{FD8DBC45-F7CC-48FF-BD8C-4477831F637D}" Bitness="always64">
        <File Id="jfdvrserver.exe" Source="jfdvr-server.exe" KeyPath="yes">
          <fire:FirewallException Id="FirewallRule_WEB" Name="jfDVR_Server_WEB" Protocol="tcp" Port="80,443" Scope="any" IgnoreFailure="yes" Profile="all" />
          <fire:FirewallException Id="FirewallRule_RTSP" Name="jfDVR_Server_RTSP" Protocol="tcp" Port="554" Scope="any" IgnoreFailure="yes" Profile="all" />
          <fire:FirewallException Id="FirewallRule_RTP" Name="jfDVR_Server_RTP" Protocol="udp" Port="30000-50000" Scope="any" IgnoreFailure="yes" Profile="all" />
        </File>
        <File Id="jfdvrserver.jar" Source="jfdvr-server.jar" />
        <File Id="javaforce.jar" Source="javaforce.jar" />
        <ServiceInstall Id="ServiceInstaller" Type="ownProcess" Name="jfDVR Server" DisplayName="jfDVR Server" Description="jfDVR Server" Start="auto" ErrorControl="normal" />
        <ServiceControl Id="StartService" Start="install" Stop="both" Remove="uninstall" Name="jfDVR Server" Wait="yes" />
      </Component>
    </DirectoryRef>

    <!-- Step 2b: Add the shortcut to your installer package -->
    <StandardDirectory Id="ProgramMenuFolder">
    </StandardDirectory>

    <DirectoryRef Id="APPLICATIONDATADIRECTORY_JFADMIN">
      <Component Id="adminfiles" Guid="{DC7745F7-7B2E-4078-862D-EC7486BFCCBD}">
        <File Id="jfdvr_server.cfg" Source="jfdvr-server.cfg" />
      </Component>
    </DirectoryRef>

    <!-- Step 3: Tell WiX to install the files -->
    <Feature Id="MainApplication" Title="Main Application" Level="1">
      <ComponentRef Id="appfiles" />
      <ComponentRef Id="adminfiles" />
      <ComponentGroupRef Id="JRE" />
      <ComponentGroupRef Id="FFMPEG" />
    </Feature>

  </Package>
</Wix>
