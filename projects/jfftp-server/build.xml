<project name="jfftp-server" basedir=".">
  <description>ftp server</description>
  <!-- set global properties for this build -->
  <property name="app" value="jfftp-server"/>
  <property name="apptype" value="service"/>
  <property name="home" value="../.."/>
  <property name="version" value="0.1"/>
  <property name="jre" location="${home}/jre_base_desktop"/>

  <import file="${home}/base.xml"/>

  <target name="depjars" depends="depnatives">
  </target>

  <target name="compile" depends="depjars" description="compile the source">
  </target>

  <target name="jar" depends="depjars,compile" description="build jar file">
  </target>

  <target name="install" description="install files for linux">
    <copy file="${app}.service" todir="/lib/systemd/system"/>
  </target>

  <target name="zip-msi" description="zip msi packages">
    <zip destfile="jfftp-${version}.zip">
      <fileset dir="../../repo/windows/amd64">
        <include name="jfftp-*.msi"/>
      </fileset>
    </zip>
  </target>

</project>
